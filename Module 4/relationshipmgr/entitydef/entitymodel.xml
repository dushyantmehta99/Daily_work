<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
    <!-- ========================================================= -->
    <!-- ======================== Defaults ======================= -->
    <!-- ========================================================= -->
    <title>Entity of Relationshipmgr Component</title>
<!--    <description>None</description>-->
<!--    <copyright></copyright>-->
<!--    <version></version>-->


    <!-- ========================================================= -->
    <!-- Party Data Model (Supertypes and Subtypes)                -->
    <!-- ========================================================= -->
    <!-- Supertype: Party -->
    <entity entity-name="DmParty" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="partyId" type="id"/>
        <field name="partyTypeId" type="id"/>
        <prim-key field="partyId"/>
    </entity>

    <!-- SubType: Person -->
    <entity entity-name="DmPerson" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="partyId" type="id"/>
        <field name="firstName" type="name"/>
        <field name="lastName" type="name"/>
        <field name="birthDate" type="date"/>

        <prim-key field="partyId"/>

        <relation type="one" fk-name="DM_PER_PARTY" rel-entity-name="DmParty">
            <key-map field-name="partyId"/>
        </relation>
    </entity>

    <!-- SubType: Retail Store -->
    <entity entity-name="DmRetailStore" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="partyId" type="id"/>
        <field name="storeName" type="name"/>

        <prim-key field="partyId"/>

        <relation type="one" fk-name="DM_STORE_PARTY" rel-entity-name="DmParty">
            <key-map field-name="partyId"/>
        </relation>
    </entity>

    <!-- Intersection Entity: Party Role -->
    <entity entity-name="DmPartyRole" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="partyId" type="id"/>
        <field name="roleTypeId" type="id"/>

        <prim-key field="partyId"/>
        <prim-key field="roleTypeId"/>

        <relation type="one" fk-name="DM_PRL_PARTY" rel-entity-name="DmParty">
            <key-map field-name="partyId"/>
        </relation>
    </entity>


    <!-- ========================================================= -->
    <!-- Contact Mechanism Data Model                              -->
    <!-- ========================================================= -->
    <!-- Supertype: Contact Mechanism -->
    <entity entity-name="DmContactMech" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="contactMechId" type="id"/>
        <field name="contactMechTypeId" type="id"/>
        <field name="infoString" type="long-varchar"/>

        <prim-key field="contactMechId"/>
    </entity>

    <!-- Subtype: Postal Address -->
    <entity entity-name="DmPostalAddress" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="contactMechId" type="id"/>
        <field name="address1" type="name"/>
        <field name="city" type="name"/>
        <field name="postalCode" type="id"/>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="DM_PA_CMECH" rel-entity-name="DmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

    <!-- Intersection Entity: Party Contact Mechanism -->
    <entity entity-name="DmPartyContactMech" package-name="org.apache.ofbiz.relationshipmgr">
        <field name="partyId" type="id"/>
        <field name="contactMechId" type="id"/>
        <field name="fromDate" type="date-time"/>
        <field name="thruDate" type="date-time"/>
        <prim-key field="partyId"/>
        <prim-key field="contactMechId"/>
        <prim-key field="fromDate"/>
        <relation type="one" fk-name="DM_PCM_PARTY" rel-entity-name="DmParty">
            <key-map field-name="partyId"/>
        </relation>
        <relation type="one" fk-name="DM_PCM_CMECH" rel-entity-name="DmContactMech">
            <key-map field-name="contactMechId"/>
        </relation>
    </entity>

</entitymodel>
