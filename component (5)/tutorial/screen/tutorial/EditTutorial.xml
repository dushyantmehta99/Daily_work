<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">

    <actions>
        <entity-find-one entity-name="tutorial.Tutorial" value-field="tutorial">
            <field-map field-name="tutorialId" from="parameters.tutorialId"/>
        </entity-find-one>
    </actions>

    <widgets>
        <form-single name="EditTutorialForm" map="tutorial" transition="updateTutorial">
            <auto-fields-entity entity-name="tutorial.Tutorial" field-type="edit"/>
            <field name="submit">
                <default-field><submit button-text="Update"/></default-field>
            </field>
        </form-single>
    </widgets>

    <transition name="updateTutorial">
        <service-call name="tutorial.TutorialServices.update#Tutorial"/>
        <default-response url="FindTutorial"/>
    </transition>

</screen>