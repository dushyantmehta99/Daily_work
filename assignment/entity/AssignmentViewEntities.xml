<?xml version="1.0" encoding="UTF-8"?>

<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <view-entity entity-name="CustomerSignupView"
                 package-name="assignment">

        <member-entity entity-alias="P"
                       entity-name="Party"/>

        <member-entity entity-alias="PR"
                       entity-name="PartyRole"
                       join-from-alias="P">
            <key-map field-name="partyId"/>
        </member-entity>

        <member-entity entity-alias="PE"
                       entity-name="Person"
                       join-from-alias="P">
            <key-map field-name="partyId"/>
        </member-entity>

        <member-entity entity-alias="PCM_EMAIL"
                       entity-name="PartyContactMech"
                       join-from-alias="P"
                       join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>

        <member-entity entity-alias="CM_EMAIL"
                       entity-name="ContactMech"
                       join-from-alias="PCM_EMAIL"
                       join-optional="true">
            <key-map field-name="contactMechId"/>
        </member-entity>

        <member-entity entity-alias="PCM_PHONE"
                       entity-name="PartyContactMech"
                       join-from-alias="P"
                       join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>

        <member-entity entity-alias="TN"
                       entity-name="TelecomNumber"
                       join-from-alias="PCM_PHONE"
                       join-optional="true">
            <key-map field-name="contactMechId"/>
        </member-entity>


        <alias entity-alias="P" name="partyId"/>
        <alias entity-alias="P" name="createdStamp"/>
        <alias entity-alias="PE" name="firstName"/>
        <alias entity-alias="PE" name="lastName"/>
        <alias entity-alias="PR" name="roleTypeId"/>
        <alias entity-alias="CM_EMAIL"
               name="infoString"
               alias="email"/>
        <alias entity-alias="TN"
               name="contactNumber"
               alias="phone"/>

    </view-entity>
     

     <view-entity entity-name="CompletedOrdersList"
             package-name="assignment">
    <member-entity entity-alias="OH"
                   entity-name="OrderHeader"/>
    <member-entity entity-alias="OI"
                   entity-name="OrderItem"
                   join-from-alias="OH">
        <key-map field-name="orderId"/>
    </member-entity>
    <member-entity entity-alias="P"
                   entity-name="Product"
                   join-from-alias="OI">
        <key-map field-name="productId"/>
    </member-entity>
    <member-entity entity-alias="OHIS"
                   entity-name="OrderHistory"
                   join-from-alias="OH"
                   join-optional="true">
        <key-map field-name="orderId"/>
    </member-entity>
    <member-entity entity-alias="OISG"
                   entity-name="OrderItemShipGroup"
                   join-from-alias="OH"
                   join-optional="true">
        <key-map field-name="orderId"/>
    </member-entity>
    <member-entity entity-alias="F"
                   entity-name="Facility"
                   join-from-alias="OISG"
                   join-optional="true">
        <key-map field-name="facilityId"/>
    </member-entity>

    <alias entity-alias="OI" name="productId"/>
    <alias entity-alias="P" name="productTypeId"/>
    <alias entity-alias="OH" name="productStoreId"/>
    <alias entity-alias="OI" name="quantity" alias="totalQuantity"/>
    <alias entity-alias="P" name="internalName"/>
    <alias entity-alias="F" name="facilityId"/>
    <alias entity-alias="F" name="externalId"/>
    <alias entity-alias="F" name="facilityTypeId"/>
    <alias entity-alias="OHIS" name="orderHistoryId"/>
    <alias entity-alias="OH" name="orderId"/>
    <alias entity-alias="OI" name="orderItemSeqId"/>
    <alias entity-alias="OISG" name="shipGroupSeqId"/>
    <alias entity-alias="OH" name="statusId"/>
    <alias entity-alias="OH" name="orderDate"/>

</view-entity>

    <view-entity entity-name="OrdersWithoutShipmentView"
                 package-name="assignment">

        <member-entity entity-alias="OH"
                       entity-name="OrderHeader"/>
        <member-entity entity-alias="OI"
                       entity-name="OrderItem"
                       join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="OISG"
                       entity-name="OrderItemShipGroup"
                       join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="S"
                       entity-name="Shipment"
                       join-from-alias="OH"
                       join-optional="true">
            <key-map field-name="orderId"
                     related="primaryOrderId"/>
        </member-entity>

        <alias entity-alias="OH" name="orderId"/>
        <alias entity-alias="OH" name="orderDate"/>
        <alias entity-alias="OH" name="statusId"/>
        <alias entity-alias="S" name="shipmentId"/>
        <alias entity-alias="OI" name="quantity" alias="totalQuantity" function="sum"/>
        
    </view-entity>

    <view-entity entity-name="shippedorders" package="assignment">
        <member-entity entity-alias="OH"  entity-name="OrderHeader"/>
        <member-entity entity-alias="ORL" entity-name="OrderRole" join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="P"   entity-name="Person" join-from-alias="ORL">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="OCM" entity-name="OrderContactMech" join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="PA"  entity-name="PostalAddress" join-from-alias="OCM">
            <key-map field-name="contactMechId"/>
        </member-entity>
        <member-entity entity-alias="OS"  entity-name="OrderStatus" join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>

        <alias entity-alias="OH"  name="orderId"/>
        <alias entity-alias="ORL" name="partyId"/>
        <alias entity-alias="ORL" name="roleTypeId"/>
        <alias entity-alias="P"   name="firstName"/>
        <alias entity-alias="P"   name="lastName"/>
        <alias entity-alias="PA"  name="streetAddress"  field="address1"/>
        <alias entity-alias="PA"  name="city"/>
        <alias entity-alias="PA"  name="stateProvince"  field="stateProvinceGeoId"/>
        <alias entity-alias="PA"  name="postalCode"/>
        <alias entity-alias="PA"  name="countryCode"    field="countryGeoId"/>
        <alias entity-alias="OH"  name="orderStatusId"  field="statusId"/>
        <alias entity-alias="OH"  name="orderDate"      field="placedDate"/>
        <alias entity-alias="OCM" name="contactMechPurposeTypeId"/>
        <alias entity-alias="OS"  name="statusId"/>
        <alias entity-alias="OS"  name="statusDatetime"/>
    </view-entity>

    <view-entity entity-name="CompletedSalesOrdersPhysicalView"
                 package-name="assignment">

        <member-entity entity-alias="OH"
                       entity-name="OrderHeader"/>
        <member-entity entity-alias="OI"
                       entity-name="OrderItem"
                       join-from-alias="OH">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="P"
                       entity-name="Product"
                       join-from-alias="OI"
                       join-optional="true">
            <key-map field-name="productId"/>
        </member-entity>
        <member-entity entity-alias="PT"
                       entity-name="ProductType"
                       join-from-alias="P">
            <key-map field-name="productTypeId"/>
        </member-entity>
        <member-entity entity-alias="OS"
                       entity-name="OrderStatus"
                       join-from-alias="OI"
                       join-optional="true">
            <key-map field-name="orderId"/>
            <key-map field-name="orderItemSeqId"/>
            <entity-condition>
                <econdition field-name="statusId" value="ITEM_COMPLETED"/>
            </entity-condition>
        </member-entity>

        <alias entity-alias="OI" name="orderId"/>
        <alias entity-alias="OI" name="orderItemSeqId"/>
        <alias entity-alias="OI" field="statusId" name="itemStatusId"/>
        <alias entity-alias="P"  name="productId"/>
        <alias entity-alias="P"  name="productTypeId"/>
        <alias entity-alias="PT" name="isPhysical"/>
        <alias entity-alias="OH" name="salesChannelEnumId"/>
        <alias entity-alias="OH" name="orderDate"/>
        <alias entity-alias="OH" name="entryDate"/>
        <alias entity-alias="OH" name="statusId"/>
        <alias entity-alias="OH" name="orderTypeId"/>
        <alias entity-alias="OH" name="productStoreId"/>
        <alias entity-alias="OS" name="statusDatetime"/>

    </view-entity>

</entities>