<?xml version="1.0" encoding="UTF-8"?>
<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Widget-Form"
        xsi:schemaLocation="http://ofbiz.apache.org/Widget-Form http://ofbiz.apache.org/dtds/widget-form.xsd">

    <!-- Find Product search form -->
    <form name="FindProductForm" type="single" target="findProduct" title="Find Product">
        <field name="productId"            title="Product ID">
            <text-find default-option="contains" ignore-case="true"/>
        </field>
        <field name="productName"          title="Product Name">
            <text-find default-option="contains" ignore-case="true"/>
        </field>
        <field name="minPrice"             title="Min Price">
            <text/>
        </field>
        <field name="maxPrice"             title="Max Price">
            <text/>
        </field>
        <field name="productFeatureTypeId" title="Feature Type (e.g. COLOR, SIZE)">
            <text/>
        </field>
        <field name="featureDescription"   title="Feature Description">
            <text/>
        </field>
        <field name="submitButton" title="">
            <submit button-type="button"/>
        </field>
    </form>

    <!-- Create Product form -->
    <form name="CreateProductForm" type="single" target="createProduct" title="Create Product">
        <field name="productName"      title="Product Name" required-field="true"><text/></field>
        <field name="productCategoryId" title="Category ID"  required-field="true"><text/></field>
        <field name="price"            title="Price"        required-field="true"><text/></field>
        <field name="currencyUomId"    title="Currency">
            <text default-value="USD"/>
        </field>
        <field name="submitButton" title="">
            <submit button-type="button"/>
        </field>
    </form>

    <!-- Update Product form -->
    <form name="UpdateProductForm" type="single" target="updateProduct" title="Update Product">
        <field name="productId"       title="Product ID" required-field="true"><text/></field>
        <field name="price"           title="New Price"><text/></field>
        <field name="currencyUomId"   title="Currency"><text default-value="USD"/></field>
        <field name="productFeatureId" title="Add Feature ID"><text/></field>
        <field name="submitButton" title="">
            <submit button-type="button"/>
        </field>
    </form>

</forms>
