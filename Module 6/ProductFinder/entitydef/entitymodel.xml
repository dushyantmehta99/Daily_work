<?xml version="1.0" encoding="UTF-8"?>
<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">

    <title>ProductFinder Entity Model</title>
    <description>View entity for dynamic product finder. Core entities (Product, ProductPrice,
        ProductCategory, ProductFeature) are defined in applications/product.</description>

    <!-- Step 3: FindProductView — joins Product, ProductPrice, ProductFeatureAppl, ProductFeature -->
    <view-entity entity-name="FindProductView" package-name="org.apache.ofbiz.productmgmt"
            title="Find Product View">
        <member-entity entity-alias="P"   entity-name="Product"/>
        <member-entity entity-alias="PP"  entity-name="ProductPrice"         join-from-alias="P">
            <key-map field-name="productId"/>
        </member-entity>
        <member-entity entity-alias="PFA" entity-name="ProductFeatureAppl"   join-from-alias="P" join-optional="true">
            <key-map field-name="productId"/>
        </member-entity>
        <member-entity entity-alias="PF"  entity-name="ProductFeature"       join-from-alias="PFA" join-optional="true">
            <key-map field-name="productFeatureId"/>
        </member-entity>
        <member-entity entity-alias="PCM" entity-name="ProductCategoryMember" join-from-alias="P" join-optional="true">
            <key-map field-name="productId"/>
        </member-entity>

        <alias entity-alias="P"   name="productId"/>
        <alias entity-alias="P"   name="productName" field="internalName"/>
        <alias entity-alias="P"   name="productTypeId"/>
        <alias entity-alias="P"   name="isVirtual"/>
        <alias entity-alias="P"   name="isVariant"/>
        <alias entity-alias="PP"  name="price"/>
        <alias entity-alias="PP"  name="productPriceTypeId"/>
        <alias entity-alias="PP"  name="currencyUomId"/>
        <alias entity-alias="PF"  name="productFeatureId"/>
        <alias entity-alias="PF"  name="featureDescription" field="description"/>
        <alias entity-alias="PF"  name="productFeatureTypeId"/>
        <alias entity-alias="PCM" name="productCategoryId"/>

        <view-link entity-alias="P" rel-entity-alias="PP">
            <key-map field-name="productId"/>
        </view-link>
        <view-link entity-alias="P" rel-entity-alias="PFA" rel-optional="true">
            <key-map field-name="productId"/>
        </view-link>
        <view-link entity-alias="PFA" rel-entity-alias="PF" rel-optional="true">
            <key-map field-name="productFeatureId"/>
        </view-link>
        <view-link entity-alias="P" rel-entity-alias="PCM" rel-optional="true">
            <key-map field-name="productId"/>
        </view-link>
    </view-entity>

</entitymodel>
