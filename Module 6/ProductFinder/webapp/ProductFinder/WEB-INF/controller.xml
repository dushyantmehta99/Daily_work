<?xml version="1.0" encoding="UTF-8"?>
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf"
        xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">

    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>
    <description>ProductFinder Component Controller</description>

    <!-- ==================== Request Mappings ==================== -->

    <request-map uri="main">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="main"/>
    </request-map>

    <!-- Step 7: findProduct event -->
    <request-map uri="findProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="findProduct"/>
        <response name="success" type="view" value="findProduct"/>
        <response name="error"   type="view" value="findProduct"/>
    </request-map>

    <!-- Step 7: createProduct event -->
    <request-map uri="createProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="createProduct"/>
        <response name="success" type="view" value="findProduct"/>
        <response name="error"   type="view" value="createProduct"/>
    </request-map>

    <!-- Step 7: updateProduct event -->
    <request-map uri="updateProduct">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateProduct"/>
        <response name="success" type="view" value="findProduct"/>
        <response name="error"   type="view" value="findProduct"/>
    </request-map>

    <request-map uri="assocProductToVirtual">
        <security https="true" auth="true"/>
        <event type="service" invoke="assocProductToVirtual"/>
        <response name="success" type="view" value="findProduct"/>
        <response name="error"   type="view" value="findProduct"/>
    </request-map>

    <request-map uri="updateProductVariant">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateProductVariant"/>
        <response name="success" type="view" value="findProduct"/>
        <response name="error"   type="view" value="findProduct"/>
    </request-map>

    <!-- ==================== View Mappings ==================== -->

    <view-map name="main"          type="screen" page="component://ProductFinder/widget/ProductMgmtScreens.xml#main"/>
    <view-map name="findProduct"   type="ftl"    page="component://ProductFinder/webapp/ProductFinder/template/findProduct.ftl"/>
    <view-map name="createProduct" type="screen" page="component://ProductFinder/widget/ProductMgmtScreens.xml#createProduct"/>

</site-conf>
