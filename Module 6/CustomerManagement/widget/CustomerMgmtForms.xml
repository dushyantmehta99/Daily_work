<?xml version="1.0" encoding="UTF-8"?>
<forms xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/widget-form.xsd">

    <form name="FindCustomerForm" type="single" target="findCustomer">
        <field name="partyId">       <text/></field>
        <field name="firstName">     <text/></field>
        <field name="lastName">      <text/></field>
        <field name="emailAddress">  <text/></field>
        <field name="contactNumber"> <text/></field>
        <field name="address1">      <text/></field>
        <field name="submitButton" title="Search">
            <submit button-type="button"/>
        </field>
    </form>

    <form name="CreateCustomerForm" type="single" target="createCustomer">
        <field name="emailAddress"   required-field="true"><text/></field>
        <field name="firstName"      required-field="true"><text/></field>
        <field name="lastName"       required-field="true"><text/></field>
        <field name="contactNumber">  <text/></field>
        <field name="address1">       <text/></field>
        <field name="city">           <text/></field>
        <field name="zipOrPostalCode"><text/></field>
        <field name="submitButton" title="Create Customer">
            <submit button-type="button"/>
        </field>
    </form>

    <form name="UpdateCustomerForm" type="single" target="updateCustomer">
        <field name="emailAddress"    required-field="true"><display/></field>
        <field name="contactNumber">  <text/></field>
        <field name="address1">       <text/></field>
        <field name="city">           <text/></field>
        <field name="zipOrPostalCode"><text/></field>
        <field name="submitButton" title="Update Customer">
            <submit button-type="button"/>
        </field>
    </form>

</forms>
