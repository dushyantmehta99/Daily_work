<?xml version="1.0" encoding="UTF-8"?>
<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">

    <title>Customer Management Entity Model</title>

    <!--
        FindCustomerView — joins Party + Person with email ContactMech via PartyContactMechPurpose.
        Filter by contactMechPurposeTypeId="EmailPrimary" in services to get each customer's primary email.
    -->
    <view-entity entity-name="FindCustomerView" package-name="org.apache.ofbiz.customermgmt"
            title="View-entity for customer lookup with email as unique identifier">

        <member-entity entity-alias="PT"   entity-name="Party"/>
        <member-entity entity-alias="PER"  entity-name="Person" join-from-alias="PT">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="PCMP" entity-name="PartyContactMechPurpose" join-from-alias="PT" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="CM"   entity-name="ContactMech" join-from-alias="PCMP" join-optional="true">
            <key-map field-name="contactMechId"/>
        </member-entity>

        <alias entity-alias="PT"   name="partyId"/>
        <alias entity-alias="PT"   name="partyTypeId"/>
        <alias entity-alias="PER"  name="firstName"/>
        <alias entity-alias="PER"  name="lastName"/>
        <alias entity-alias="PCMP" name="contactMechId"/>
        <alias entity-alias="PCMP" name="contactMechPurposeTypeId"/>
        <alias entity-alias="CM"   name="emailAddress" field="infoString"/>
    </view-entity>

</entitymodel>
