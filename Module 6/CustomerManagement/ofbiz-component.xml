<?xml version="1.0" encoding="UTF-8"?>
<ofbiz-component name="CustomerManagement"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/ofbiz-component.xsd">

    <resource-loader name="main" type="component"/>

    <classpath type="dir" location="config"/>

    <entity-resource type="model" reader-name="main" loader="main" location="entitydef/entitymodel.xml"/>
    <entity-resource type="data" reader-name="seed" loader="main" location="data/CustomerManagementSeedData.xml"/>

    <service-resource type="model" loader="main" location="servicedef/services.xml"/>

    <webapp name="CustomerManagement"
        title="Customer Management"
        server="default-server"
        location="webapp/CustomerManagement"
        base-permission="OFBTOOLS,CUSTOMERMGMT"
        mount-point="/CustomerManagement"/>

</ofbiz-component>
