	"item": [
		{
			"name": "find open orders",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"let response = pm.response.json();",
							"",
							"let groups =",
							"response.grouped.orderItemShipGroupIdentifier.groups;",
							"",
							"let shipmentGroups = [];",
							"",
							"groups.forEach(group => {",
							"",
							"    let docs = group.doclist.docs;",
							"",
							"    let orderItems = [];",
							"",
							"    docs.forEach(doc => {",
							"",
							"        orderItems.push({",
							"            orderId: doc.orderId,",
							"            orderItemSeqId: doc.orderItemSeqId,",
							"            shipGroupSeqId: doc.shipGroupSeqId,",
							"            productId: doc.productId,",
							"            quantity: doc.quantity",
							"        });",
							"",
							"    });",
							"",
							"    shipmentGroups.push({",
							"        orderId: docs[0].orderId,",
							"        shipGroupSeqId: docs[0].shipGroupSeqId,",
							"        orderItems: orderItems",
							"    });",
							"",
							"});",
							"",
							"pm.environment.set(",
							"    \"shipmentGroups\",",
							"    JSON.stringify(shipmentGroups)",
							");",
							"",
							"pm.environment.set(",
							"    \"groupIndex\",",
							"    0",
							");",
							"",
							"console.log(",
							"    \"Groups Found:\",",
							"    shipmentGroups.length",
							");"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
