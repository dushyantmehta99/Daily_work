							"    pm.environment.get(\"shipmentGroups\")",
							");",
							"",
							"let index =",
							"parseInt(",
							"    pm.environment.get(\"groupIndex\")",
							");",
							"",
							"index++;",
							"",
							"pm.environment.set(",
							"    \"groupIndex\",",
