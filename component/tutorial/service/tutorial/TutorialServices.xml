<?xml version="1.0" encoding="UTF-8"?>
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">

    <!-- ================= CREATE ================= -->
    <service verb="create" noun="Tutorial" type="inline">
        <in-parameters>
            <parameter name="description"/>
            <auto-parameters entity-name="tutorial.Tutorial" include="all"/>
        </in-parameters>
        <out-parameters>
            <parameter name="tutorialId" required="true"/>
        </out-parameters>
        <actions>
            <entity-make-value entity-name="tutorial.Tutorial" value-field="tutorial"/>
            <entity-set value-field="tutorial" include="all"/>
            <if condition="!tutorial.tutorialId">
                <entity-sequenced-id-primary value-field="tutorial"/>
            </if>
            <entity-create value-field="tutorial"/>
        </actions>
    </service>

    <!-- ================= READ ================= -->
    <service verb="get" noun="Tutorial" type="inline">
        <in-parameters>
            <parameter name="tutorialId" required="true"/>
        </in-parameters>
        <out-parameters>
            <auto-parameters entity-name="tutorial.Tutorial" include="all"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="tutorial.Tutorial" value-field="tutorial">
                <field-map field-name="tutorialId"/>
            </entity-find-one>
            <if condition="!tutorial">
                <return type="error" message="Tutorial not found with ID: ${tutorialId}"/>
            </if>
            <entity-set value-field="tutorial" include="all"/>
        </actions>
    </service>

    <!-- ================= UPDATE WITH VALIDATION ================= -->
    <service verb="update" noun="Tutorial" type="inline">
        <in-parameters>
            <parameter name="tutorialId" required="true"/>
            <parameter name="description"/>
        </in-parameters>
        <out-parameters>
            <parameter name="tutorialId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="tutorial.Tutorial" value-field="tutorial" for-update="true">
                <field-map field-name="tutorialId"/>
            </entity-find-one>
            <if condition="!tutorial">
                <return type="error" message="Tutorial not found with ID: ${tutorialId}"/>
            </if>
            <entity-set value-field="tutorial" include="non-pk"/>
            <entity-update value-field="tutorial"/>
        </actions>
    </service>

    <!-- ================= DELETE WITH ERROR HANDLING ================= -->
    <service verb="delete" noun="Tutorial" type="inline">
        <in-parameters>
            <parameter name="tutorialId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="message" type="String"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="tutorial.Tutorial" value-field="tutorial">
                <field-map field-name="tutorialId"/>
            </entity-find-one>
            <if condition="!tutorial">
                <set field="message" value="Tutorial not found with ID: ${tutorialId}"/>
                <return type="error" message="${message}"/>
            </if>
            <entity-delete value-field="tutorial"/>
            <set field="message" value="Tutorial deleted successfully"/>
        </actions>
    </service>

</services>